<div class="emotive-hud">
    <div class="hud-controls">
        <button class="control-button drag-handle" title="Drag to move window" type="button">
            <i class="fas fa-grip-lines"></i>
        </button>
        {{#if isGM}}
            <button class="control-button open-selector" title="Open Emotive HUD Actor Selector" type="button">
                <i class="fas fa-bars"></i>
            </button>
        {{/if}}
        <button class="control-button toggle-visibility" title="{{#if isMinimized}}Show{{else}}Hide{{/if}} Emotive HUD" type="button">
            <i class="fas fa-chevron-{{#if isMinimized}}up{{else}}down{{/if}}"></i>
        </button>
    </div>
    {{#unless isMinimized}}
        <div class="portrait-container" style="--portrait-count: {{portraits.length}}; --grid-columns: {{columns}}; --floatingPortraitWidth: {{floatingPortraitWidth}}px">
            {{#each portraits}}
            <div class="portrait" data-actor-id="{{actorId}}" style="--portrait-ratio: {{emotivePortraitRatio}}">
                <img src="{{imgSrc}}" alt="{{name}}">
            </div>
            {{/each}}
        </div>
    {{/unless}}
</div>